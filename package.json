{
  "name": "claudecode",
  "version": "0.1.0",
  "type": "module",
  "description": "Desktop app for AI with Office files",
  "author": "Claude",
  "main": "./out/main/main.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --publish never",
    "dist": "electron-builder",
    "lint": "eslint .",
